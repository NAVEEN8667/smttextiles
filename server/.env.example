PORT=5000
DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require
JWT_SECRET=replace_with_a_long_random_secret

# Preferred in production (avoids SMTP network blocks on hosts like Render)
BREVO_API_KEY=xkeysib_replace_with_api_key
EMAIL_FROM=no-reply@your-domain.com
BREVO_SENDER_NAME=SM Textiles

# Optional fallback sender identity if EMAIL_FROM is not set
EMAIL_USER=replace_with_email@example.com
RAZORPAY_KEY_ID=replace_with_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret

# Optional (recommended in production)
FRONTEND_URL=https://your-frontend-domain.vercel.app
CORS_ORIGINS=https://your-frontend-domain.vercel.app

# Optional local development fallback (only used when DATABASE_URL is not set)
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=textile_db
